# =============================================================================
# agent-stella environment variables
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# Required — OpenAI API key for Realtime voice API
OPENAI_API_KEY=sk-...

# Required — Google account for Chrome auto-login to Google Meet
GOOGLE_EMAIL=stella@yourdomain.com
GOOGLE_PASSWORD=your-google-password

# TOTP secret for automated 2FA login (base32-encoded)
# Required if the Google account has 2-Step Verification with an authenticator app
GOOGLE_TOTP_SECRET=JBSWY3DPEHPK3PXP

# Service account JSON for Google Calendar, Meet, and Drive APIs
# See README.md for setup instructions
GOOGLE_CREDENTIALS_FILE=/app/data/credentials/service-account.json

# Google app password (enables IMAP email scanning)
# Generate at https://myaccount.google.com/apppasswords
GOOGLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Google Calendar ID (optional, defaults to "primary" = the account's main calendar)
# GOOGLE_CALENDAR_ID=primary

# Agent name shown in Google Meet (default: Igor)
STELLA_AGENT_NAME=Igor

# Email subject keywords to watch for transcriptions (comma-separated)
STELLA_EMAIL_KEYWORDS=notes,transcript,meeting,summary,recording

# Enable Gemini notes/transcription for daemon joins (default: true)
STELLA_ENABLE_NOTES=true

# Auto-admit waiting guests for daemon joins (default: true)
STELLA_AUTO_ACCEPT_GUESTS=true

# stella-rag connection (optional — enables knowledge base and briefings)
STELLA_RAG_URL=http://host.docker.internal:8000
STELLA_RAG_KEY=your-rag-api-key

# Scan intervals in minutes (optional)
# STELLA_CALENDAR_INTERVAL=5
# STELLA_EMAIL_INTERVAL=10

# Agent owner — enables email notifications for new meetings
AGENT_OWNER_NAME=Your Name
AGENT_OWNER_EMAIL=you@example.com

# Voice and language defaults (optional)
STELLA_DEFAULT_VOICE=coral
STELLA_DEFAULT_LANG=español

# Chrome CDP address — do not change unless you know what you're doing
CHROME_DEBUG_ADDR=http://127.0.0.1:18800
