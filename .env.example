# =============================================================================
# agent-stella environment variables
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# Required — OpenAI API key for Realtime voice API
OPENAI_API_KEY=sk-...

# Required — Google account for Chrome auto-login to Google Meet
GOOGLE_EMAIL=stella@yourdomain.com
GOOGLE_PASSWORD=your-google-password

# Google app password (enables Calendar + Email access)
# Generate at https://myaccount.google.com/apppasswords
GOOGLE_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Google Calendar ID (optional, defaults to "primary" = the account's main calendar)
# Only change if meetings are on a different calendar (e.g., a shared team calendar)
# To find a calendar ID: Google Calendar → Settings → click the calendar → "Integrate calendar" → Calendar ID
# GOOGLE_CALENDAR_ID=primary

# Email transcription senders to watch (optional, comma-separated)
STELLA_EMAIL_SENDERS=notifications@otter.ai,notifications@fireflies.ai,meet-recordings-noreply@google.com

# stella-rag connection (optional — enables knowledge base and briefings)
STELLA_RAG_URL=http://host.docker.internal:8000
STELLA_RAG_KEY=your-rag-api-key

# Voice and language defaults (optional)
STELLA_DEFAULT_VOICE=coral
STELLA_DEFAULT_LANG=español

# Chrome CDP address — do not change unless you know what you're doing
CHROME_DEBUG_ADDR=http://127.0.0.1:18800
