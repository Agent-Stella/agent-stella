# =============================================================================
# stella-rag — Docker image for Stella RAG knowledge base server
# Pre-built binary + Python parsers for PDF/DOCX/PPTX
# =============================================================================

FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        python3 python3-pip \
        postgresql-client \
    && pip3 install --break-system-packages \
        pymupdf4llm python-docx python-pptx trafilatura \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy pre-built binary
ARG TARGETARCH
COPY bin/stella-linux-${TARGETARCH} /usr/local/bin/stella

# Copy Python parsing script
COPY parse/stella_parse.py /app/parse.py

EXPOSE 8080

# Run migrations on start, then serve
CMD ["sh", "-c", "stella rag migrate && stella rag serve"]
